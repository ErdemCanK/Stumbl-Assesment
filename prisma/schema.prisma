// Prisma schema for the Stumbl trainee assessment.
//
// This schema is intentionally small. The candidate is expected to extend
// indexes, relations, or add new models as their API design requires.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SignalType {
  SUPPORT_NEEDED
  SUPPORT_OFFERED
  GENERAL
}

enum Visibility {
  PUBLIC
  PRIVATE
  ORGANISATION_ONLY
}

enum SignalCategory {
  Awareness
  Support
  Opportunity
  Alert
  Question
}

enum SignalPriority {
  HIGH
  MEDIUM
  LOW
}

enum AuthorRole {
  SERVICE_USER
  PRACTITIONER
  STUDENT
  SUPPORTER
}

enum SwipeAction {
  PASS
  MATCH
  NETWORK_REFER
}

model Author {
  id           String     @id @default(cuid())
  displayName  String
  avatarUrl    String?
  role         AuthorRole
  verified     Boolean    @default(false)
  organisation String?

  signals           Signal[]
  referralContacts  ReferralContact[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Signal {
  id          String         @id @default(cuid())
  title       String
  description String
  type        SignalType
  category    SignalCategory
  priority    SignalPriority
  visibility  Visibility     @default(PUBLIC)
  location    String
  interests   String[]

  author   Author @relation(fields: [authorId], references: [id])
  authorId String

  decisions Decision[]
  referrals Referral[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([priority])
}

model Decision {
  id       String      @id @default(cuid())
  signal   Signal      @relation(fields: [signalId], references: [id])
  signalId String
  action   SwipeAction
  userId   String       // candidate may stub with a constant id; no auth required
  createdAt DateTime    @default(now())

  @@index([userId])
}

model ReferralContact {
  id           String     @id @default(cuid())
  author       Author     @relation(fields: [authorId], references: [id])
  authorId     String     @unique
  displayName  String
  role         AuthorRole
  organisation String?
  avatarUrl    String?

  referrals ReferralRecipient[]
}

model Referral {
  id       String   @id @default(cuid())
  signal   Signal   @relation(fields: [signalId], references: [id])
  signalId String
  note     String?
  sentBy   String   // stub user id
  createdAt DateTime @default(now())

  recipients ReferralRecipient[]
}

model ReferralRecipient {
  referral    Referral        @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referralId  String
  contact     ReferralContact @relation(fields: [contactId], references: [id])
  contactId   String

  @@id([referralId, contactId])
}
